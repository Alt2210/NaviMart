NODE_ENV=development
PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/navimart?retryWrites=true&w=majority
MONGODB_DB_NAME=navimart

CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=change-this-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
EXPIRY_NOTIFICATION_CRON=0 8 * * *

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=navimart

# TimelyGPT (AI Chef) - lay API key tai timelygpt.co.kr
TIMELY_API_KEY=
TIMELY_BASE_URL=https://hello.timelygpt.co.kr/api/v2/chat
TIMELY_MODEL=gpt-4o-mini

# Gmail API mail
PASSWORD_RESET_MAIL_MODE=gmail-api
GMAIL_FROM_EMAIL=your@gmail.com
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
