@startuml
title Module 5 - Meals (Detailed Class Diagram)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "View" {
    class MealPlanner <<Boundary>> {
        - state: any
        - props: any
        + render(): JSX.Element
    }
}

package "API Client" {
    class MealsApiClient <<Boundary>> {
        - baseUrl: String
        + findAll(data: any): Promise<any>
        + create(data: any): Promise<any>
        + findOne(data: any): Promise<any>
        + getMissingIngredients(data: any): Promise<any>
        + generateShoppingList(data: any): Promise<any>
        + update(data: any): Promise<any>
        + remove(data: any): Promise<any>
    }
}

package "Controller" {
    class MealsController <<Control>> {
        + findAll(@Body dto: any): Response
        + create(@Body dto: any): Response
        + findOne(@Body dto: any): Response
        + getMissingIngredients(@Body dto: any): Response
        + generateShoppingList(@Body dto: any): Response
        + update(@Body dto: any): Response
        + remove(@Body dto: any): Response
    }
}

package "Service" {
    class MealsService <<Control>> {
        + findAll(data: any): any
        + create(data: any): any
        + findOne(data: any): any
        + getMissingIngredients(data: any): any
        + generateShoppingList(data: any): any
        + update(data: any): any
        + remove(data: any): any
    }
}

package "Entity / DTO" {
    abstract class BaseEntity {
        - created_at: Date
        - updated_at: Date
    }
    class MealPlansEntity <<Entity>> {
        - plan_id: INT
        - group_id: INT
        - date: DATE
        - meal_type: VARCHAR
        - recipe_id: INT
        - is_completed: BOOLEAN
    }
    BaseEntity <|-- MealPlansEntity
}

' --- Relationships ---
MealPlanner --> MealsApiClient : "calls"
MealsApiClient ..> MealsController : "HTTP REST"
MealsController --> MealsService : "injects"
MealsService ..> MealPlansEntity : "CRUD"

@enduml
