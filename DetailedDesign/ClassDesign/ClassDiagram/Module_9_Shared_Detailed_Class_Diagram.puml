@startuml
title Module 9 - Shared (Detailed Class Diagram)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "View" {
    class Home <<Boundary>> {
        - state: any
        - props: any
        + render(): JSX.Element
    }
    class AIChef <<Boundary>> {
        - state: any
        - props: any
        + render(): JSX.Element
    }
    class Notifications <<Boundary>> {
        - state: any
        - props: any
        + render(): JSX.Element
    }
}

package "Context" {
    class DialogContext <<Control>> {
        - state: any
        + Provider(props: any): JSX.Element
    }
}

package "API Client" {
    class SharedApiClient <<Boundary>> {
        - baseUrl: String
    }
}

package "Controller" {
    class SharedController <<Control>> {
    }
}

package "Service" {
    class SharedService <<Control>> {
    }
}

' --- Relationships ---
Home --> DialogContext : "uses"
AIChef --> DialogContext : "uses"
Notifications --> DialogContext : "uses"
DialogContext --> SharedApiClient : "calls"
SharedApiClient ..> SharedController : "HTTP REST"
SharedController --> SharedService : "injects"

@enduml
