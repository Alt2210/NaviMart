@startuml
title Sequence Diagram - UC035 AdminLoginAndViewUsers

actor "Admin" as Actor
boundary "UserManagementUI" as UI
control "UserManagementController" as Controller
entity "UserDB" as Entity

Actor -> UI : 1. Đăng nhập với quyền Admin
activate UI
UI -> Controller : 2. loginAdmin(credentials)
activate Controller
Controller --> UI : 3. Token & Redirect
deactivate Controller

Actor -> UI : 4. Chọn "Quản lý Người dùng"
UI -> Controller : 5. getUsersList(filters)
activate Controller
Controller -> Entity : 6. queryAllUsers(filters)
activate Entity
Entity --> Controller : 7. return userList
deactivate Entity
Controller --> UI : 8. return userList
deactivate Controller
UI --> Actor : 9. Hiển thị danh sách Người dùng
deactivate UI
@enduml
