@startuml
title Communication Diagram - UC039 ViewAdminDashboard

allow_mixing
actor "User" as Actor
boundary "ViewAdminDashboardUI" as UI
control "ViewAdminDashboardController" as Controller
entity "ViewAdminDashboardDB" as Entity

Actor -right-> UI : 1: Interact
UI -right-> Controller : 2: process()
Controller -down-> Entity : 3: dbAction()
Controller -up-> UI : 4: returnData
@enduml
