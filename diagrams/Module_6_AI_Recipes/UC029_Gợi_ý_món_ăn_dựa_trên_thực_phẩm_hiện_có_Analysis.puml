@startuml
title Analysis Class Diagram - UC029 SuggestRecipes

class "SuggestRecipeUI" as UI <<boundary>> {
  + requestSuggestion() : void
  + displayRecipeList() : void
}
class "AISuggestionController" as Controller <<control>> {
  + getSuggestions() : void
}
class "PantryDB" as PantryDB <<entity>> {
  + getAvailableIngredients(userId: String) : List
}
class "AIService" as AIService <<control>> {
  + generateRecipes(ingredientList: List) : List
}

Controller -- UI
Controller -- PantryDB
Controller -- AIService
@enduml
