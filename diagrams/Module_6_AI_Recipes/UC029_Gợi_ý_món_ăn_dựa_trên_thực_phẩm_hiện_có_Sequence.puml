@startuml
title Sequence Diagram - UC029 SuggestRecipes

actor "User" as Actor
boundary "SuggestRecipeUI" as UI
control "AISuggestionController" as Controller
entity "PantryDB" as PantryDB
control "AIService" as AIService

Actor -> UI : 1. Nhấn "Gợi ý món ăn"
activate UI
UI -> Controller : 2. getSuggestions()
activate Controller
Controller -> PantryDB : 3. getAvailableIngredients(userId)
activate PantryDB
PantryDB --> Controller : 4. return ingredientList
deactivate PantryDB
Controller -> AIService : 5. generateRecipes(ingredientList)
activate AIService
AIService --> Controller : 6. return suggestedRecipes
deactivate AIService
Controller --> UI : 7. return recipeList
deactivate Controller
UI --> Actor : 8. Hiển thị danh sách món ăn gợi ý
deactivate UI
@enduml
