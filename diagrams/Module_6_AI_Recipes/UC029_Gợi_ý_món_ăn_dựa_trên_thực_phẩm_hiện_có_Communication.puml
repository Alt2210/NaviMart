@startuml
title Communication Diagram - UC029 SuggestRecipes

allow_mixing
actor "User" as Actor
boundary "SuggestRecipesUI" as UI
control "SuggestRecipesController" as Controller
entity "SuggestRecipesDB" as Entity

Actor -right-> UI : 1: Interact
UI -right-> Controller : 2: process()
Controller -down-> Entity : 3: dbAction()
Controller -up-> UI : 4: returnData
@enduml
