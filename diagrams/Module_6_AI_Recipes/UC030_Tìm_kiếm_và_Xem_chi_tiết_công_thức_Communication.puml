@startuml
title Communication Diagram - UC030 ViewRecipeDetail

allow_mixing
actor "User" as Actor
boundary "ViewRecipeDetailUI" as UI
control "ViewRecipeDetailController" as Controller
entity "ViewRecipeDetailDB" as Entity

Actor -right-> UI : 1: Interact
UI -right-> Controller : 2: process()
Controller -down-> Entity : 3: dbAction()
Controller -up-> UI : 4: returnData
@enduml
