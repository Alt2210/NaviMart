@startuml
title Sequence Diagram - UC033 ChatWithAIChef

actor "User" as Actor
boundary "AIChatUI" as UI
control "ChatController" as Controller
control "AIService" as AIService

Actor -> UI : 1. Nhập câu hỏi (VD: "Cách thay thế trứng bằng gì?")
activate UI
UI -> Controller : 2. sendMessage(question, context)
activate Controller
Controller -> AIService : 3. callAiAPI(question, context)
activate AIService
AIService --> Controller : 4. return answerText
deactivate AIService
Controller --> UI : 5. return answerText
deactivate Controller
UI --> Actor : 6. Hiển thị câu trả lời của AI Chef trong khung chat
deactivate UI
@enduml
