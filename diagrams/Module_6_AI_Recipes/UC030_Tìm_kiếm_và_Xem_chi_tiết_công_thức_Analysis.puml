@startuml
title Analysis Class Diagram - UC030 ViewRecipeDetail

class "RecipeUI" as UI <<boundary>> {
  + searchRecipes() : void
  + viewRecipeDetail() : void
  + displayDetails() : void
}
class "RecipeController" as Controller <<control>> {
  + searchRecipes(keyword: String) : void
  + getRecipeDetail(recipeId: String) : void
}
class "RecipeDB" as Entity <<entity>> {
  + queryRecipes(keyword: String) : List
  + queryRecipeById(recipeId: String) : Data
}

Controller -- UI
Controller -- Entity
@enduml
