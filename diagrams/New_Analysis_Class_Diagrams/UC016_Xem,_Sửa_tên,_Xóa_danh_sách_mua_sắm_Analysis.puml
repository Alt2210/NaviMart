@startuml
title UC016 Xem, Sửa tên, Xóa danh sách mua sắm (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + selectAction() : void
          + displayUpdate() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + handleListAction(action: String, listId: String, data: Data) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + handleListAction(action: String, listId: String, data: Data) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + handleListAction(action: String, listId: String, data: Data) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + executeDbQuery(action: String, listId: String, data: Data) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
