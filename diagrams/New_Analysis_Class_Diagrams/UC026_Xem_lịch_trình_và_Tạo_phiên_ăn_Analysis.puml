@startuml
title UC026 Xem lịch trình và Tạo phiên ăn (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "View (React Component)" {
    class View <<View>> {
        + selectDateRange() : void
          + displayMealPlan() : void
    }
}

package "API Client" {
    class ApiClient <<API Client>> {
        + getMealPlan(dateRange: Data) : void
          + createSession(date: Date, type: String) : void
    }
}

package "Backend Controller" {
    class Controller <<Controller>> {
        + getMealPlan(dateRange: Data) : void
          + createSession(date: Date, type: String) : void
    }
}

package "Backend Service" {
    class Service <<Service>> {
        + getMealPlan(dateRange: Data) : void
          + createSession(date: Date, type: String) : void
    }
}

package "Database Entity" {
    class Entity <<Entity>> {
        + querySessions(dateRange: Data) : List
          + insertSession(date: Date, type: String) : String
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
