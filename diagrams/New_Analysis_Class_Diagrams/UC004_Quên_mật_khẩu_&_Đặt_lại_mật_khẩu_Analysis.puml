@startuml
title UC004 Quên mật khẩu & Đặt lại mật khẩu (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + Submit Email() : void
          + Success Msg() : void
    }
    class ResetView <<Boundary>> {
        + Show OTP Input() : void
          + Submit OTP & New Password() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + requestReset(email) : void
          + resetPassword(otp, newPass) : void
    }
    class EmailApiClient <<Boundary>> {
        + sendOTP() : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + requestReset(email) : void
          + resetPassword(otp, newPass) : void
    }
    class EmailController <<Control>> {
        + sendOTP() : void
    }
}

package "Control" {
    class Service <<Control>> {
        + requestReset(email) : void
          + resetPassword(otp, newPass) : void
    }
    class EmailService <<Control>> {
        + sendOTP() : void
    }
}

package "Entity" {
    class UserEntity <<Entity>> {
  - user_id: INT
  - email: VARCHAR
  - phone: VARCHAR
  - password_hash: VARCHAR
  - role: VARCHAR
        + checkExists() : void
          + updatePassword() : void
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
View --> EmailApiClient : "calls"
ResetView --> ApiClient : "calls"
ResetView --> EmailApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
EmailApiClient ..> EmailController : "HTTP REST"
Controller --> Service : "injects"
EmailController --> EmailService : "injects"
Service ..> UserEntity : "CRUD"
EmailService ..> UserEntity : "CRUD"

@enduml
