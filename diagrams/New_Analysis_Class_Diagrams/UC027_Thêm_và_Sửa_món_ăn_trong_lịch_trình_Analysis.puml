@startuml
title UC027 Thêm và Sửa món ăn trong lịch trình (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + assignMealToSession() : void
          + displayResult() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + addOrUpdateMeal(sessionId: String, recipeId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + addOrUpdateMeal(sessionId: String, recipeId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + addOrUpdateMeal(sessionId: String, recipeId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + saveMealToSession(sessionId: String, recipeId: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
