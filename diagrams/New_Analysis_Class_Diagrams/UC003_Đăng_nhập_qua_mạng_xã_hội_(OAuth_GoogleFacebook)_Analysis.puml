@startuml
title UC003 Đăng nhập qua mạng xã hội (OAuth GoogleFacebook) (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + Chọn Login with Google/FB() : void
          + Success & Redirect() : void
    }
}

package "Boundary" {
    class ProviderApiClient <<Boundary>> {
        + Request Auth URL() : void
          + Đồng ý cấp quyền() : void
    }
    class ApiClient <<Boundary>> {
        + Callback with Profile Data (Email, Name) : void
    }
    class OAuthProviderApiClient <<Boundary>> {
    }
}

package "Control" {
    class ProviderController <<Control>> {
        + Request Auth URL() : void
          + Đồng ý cấp quyền() : void
    }
    class Controller <<Control>> {
        + Callback with Profile Data (Email, Name) : void
    }
    class OAuthProviderController <<Control>> {
    }
}

package "Control" {
    class ProviderService <<Control>> {
        + Request Auth URL() : void
          + Đồng ý cấp quyền() : void
    }
    class Service <<Control>> {
        + Callback with Profile Data (Email, Name) : void
    }
    class OAuthProviderService <<Control>> {
    }
}

package "Entity" {
    class UserEntity <<Entity>> {
  - user_id: INT
  - email: VARCHAR
  - phone: VARCHAR
  - password_hash: VARCHAR
  - role: VARCHAR
        + checkEmail() & autoCreateIfNeeded() : void
    }
}

' --- Relationships ---
View --> ProviderApiClient : "calls"
View --> ApiClient : "calls"
View --> OAuthProviderApiClient : "calls"
ProviderApiClient ..> ProviderController : "HTTP REST"
ApiClient ..> Controller : "HTTP REST"
OAuthProviderApiClient ..> OAuthProviderController : "HTTP REST"
ProviderController --> ProviderService : "injects"
Controller --> Service : "injects"
OAuthProviderController --> OAuthProviderService : "injects"
ProviderService ..> UserEntity : "CRUD"
Service ..> UserEntity : "CRUD"
OAuthProviderService ..> UserEntity : "CRUD"

@enduml
