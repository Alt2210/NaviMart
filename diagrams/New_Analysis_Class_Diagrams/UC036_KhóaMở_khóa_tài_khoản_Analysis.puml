@startuml
title UC036 KhóaMở khóa tài khoản (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + toggleLock() : void
          + displayStatus() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + toggleUserLock(userId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + toggleUserLock(userId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + toggleUserLock(userId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + updateUserStatus(userId: String, newStatus: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
