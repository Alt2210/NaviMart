@startuml
title UC036 KhóaMở khóa tài khoản (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "View (React Component)" {
    class View <<View>> {
        + toggleLock() : void
          + displayStatus() : void
    }
}

package "API Client" {
    class ApiClient <<API Client>> {
        + toggleUserLock(userId: String) : void
    }
}

package "Backend Controller" {
    class Controller <<Controller>> {
        + toggleUserLock(userId: String) : void
    }
}

package "Backend Service" {
    class Service <<Service>> {
        + toggleUserLock(userId: String) : void
    }
}

package "Database Entity" {
    class Entity <<Entity>> {
        + updateUserStatus(userId: String, newStatus: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
