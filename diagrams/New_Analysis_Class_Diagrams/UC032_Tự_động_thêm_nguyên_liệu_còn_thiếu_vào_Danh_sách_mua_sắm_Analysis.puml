@startuml
title UC032 Tự động thêm nguyên liệu còn thiếu vào Danh sách mua sắm (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + clickAddMissing() : void
          + displaySuccess() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + findMissingIngredients(recipeIngredients: List) : void
    }
    class ShoppingApiClient <<Boundary>> {
        + addItemsToList(missingIngredients: List) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + findMissingIngredients(recipeIngredients: List) : void
    }
    class ShoppingController <<Control>> {
        + addItemsToList(missingIngredients: List) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + findMissingIngredients(recipeIngredients: List) : void
    }
    class ShoppingService <<Control>> {
        + addItemsToList(missingIngredients: List) : void
    }
}

package "Entity" {
    class PantryEntity <<Entity>> {
        + checkAvailable(recipeIngredients: List) : List
    }
    class ShoppingEntity <<Entity>> {
        + saveItems() : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
View --> ShoppingApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
ShoppingApiClient ..> ShoppingController : "HTTP REST"
Controller --> Service : "injects"
ShoppingController --> ShoppingService : "injects"
Service ..> PantryEntity : "CRUD"
Service ..> ShoppingEntity : "CRUD"
ShoppingService ..> PantryEntity : "CRUD"
ShoppingService ..> ShoppingEntity : "CRUD"

@enduml
