@startuml
title UC018 Cập nhật và Xóa mặt hàng (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + selectItemAction() : void
          + displayUpdate() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + updateOrRemoveItem(action: String, itemId: String, data: Data) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + updateOrRemoveItem(action: String, itemId: String, data: Data) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + updateOrRemoveItem(action: String, itemId: String, data: Data) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + executeItemDbAction(action: String, itemId: String, data: Data) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
