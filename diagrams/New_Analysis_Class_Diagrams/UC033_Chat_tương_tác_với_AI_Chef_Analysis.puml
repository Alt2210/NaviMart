@startuml
title UC033 Chat tương tác với AI Chef (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + enterQuestion() : void
          + displayAnswer() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + sendMessage(question: String, context: Data) : void
    }
    class AIApiClient <<Boundary>> {
        + callAiAPI(question: String, context: Data) : String
    }
}

package "Control" {
    class Controller <<Control>> {
        + sendMessage(question: String, context: Data) : void
    }
    class AIController <<Control>> {
        + callAiAPI(question: String, context: Data) : String
    }
}

package "Control" {
    class Service <<Control>> {
        + sendMessage(question: String, context: Data) : void
    }
    class AIService <<Control>> {
        + callAiAPI(question: String, context: Data) : String
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
View --> AIApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
AIApiClient ..> AIController : "HTTP REST"
Controller --> Service : "injects"
AIController --> AIService : "injects"

@enduml
