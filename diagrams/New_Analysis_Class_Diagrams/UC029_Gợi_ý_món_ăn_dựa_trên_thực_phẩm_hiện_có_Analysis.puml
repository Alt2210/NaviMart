@startuml
title UC029 Gợi ý món ăn dựa trên thực phẩm hiện có (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + requestSuggestion() : void
          + displayRecipeList() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + getSuggestions() : void
    }
    class AIApiClient <<Boundary>> {
        + generateRecipes(ingredientList: List) : List
    }
}

package "Control" {
    class Controller <<Control>> {
        + getSuggestions() : void
    }
    class AIController <<Control>> {
        + generateRecipes(ingredientList: List) : List
    }
}

package "Control" {
    class Service <<Control>> {
        + getSuggestions() : void
    }
    class AIService <<Control>> {
        + generateRecipes(ingredientList: List) : List
    }
}

package "Entity" {
    class PantryEntity <<Entity>> {
        + getAvailableIngredients(userId: String) : List
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
View --> AIApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
AIApiClient ..> AIController : "HTTP REST"
Controller --> Service : "injects"
AIController --> AIService : "injects"
Service ..> PantryEntity : "CRUD"
AIService ..> PantryEntity : "CRUD"

@enduml
