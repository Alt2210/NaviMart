@startuml
title UC013 Xóa thành viên khỏi nhóm (Kick) (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + selectMemberToRemove() : void
          + displayResult() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + removeMember(groupId: String, memberId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + removeMember(groupId: String, memberId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + removeMember(groupId: String, memberId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + deleteMember(groupId: String, memberId: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
