@startuml
title UC030 Tìm kiếm và Xem chi tiết công thức (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + searchRecipes() : void
          + viewRecipeDetail() : void
          + displayDetails() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + searchRecipes(keyword: String) : void
          + getRecipeDetail(recipeId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + searchRecipes(keyword: String) : void
          + getRecipeDetail(recipeId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + searchRecipes(keyword: String) : void
          + getRecipeDetail(recipeId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + queryRecipes(keyword: String) : List
          + queryRecipeById(recipeId: String) : Data
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
