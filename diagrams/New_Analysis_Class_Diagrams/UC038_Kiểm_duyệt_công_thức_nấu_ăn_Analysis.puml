@startuml
title UC038 Kiểm duyệt công thức nấu ăn (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + viewPendingRecipes() : void
          + approveOrReject() : void
          + displayResult() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + getPendingRecipes() : void
          + approveOrRejectRecipe(recipeId: String, status: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + getPendingRecipes() : void
          + approveOrRejectRecipe(recipeId: String, status: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + getPendingRecipes() : void
          + approveOrRejectRecipe(recipeId: String, status: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + queryPending() : List
          + updateRecipeStatus(recipeId: String, status: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
