@startuml
title UC011 Tham gia nhóm gia đình (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "View (React Component)" {
    class View <<View>> {
        + enterInviteCode() : void
          + displaySuccess() : void
    }
}

package "API Client" {
    class ApiClient <<API Client>> {
        + joinGroup(inviteCode: String) : void
    }
}

package "Backend Controller" {
    class Controller <<Controller>> {
        + joinGroup(inviteCode: String) : void
    }
}

package "Backend Service" {
    class Service <<Service>> {
        + joinGroup(inviteCode: String) : void
    }
}

package "Database Entity" {
    class Entity <<Entity>> {
        + validateToken(inviteCode: String) : Boolean
          + addMemberToGroup(userId: String, groupId: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
