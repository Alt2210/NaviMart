@startuml
title UC011 Tham gia nhóm gia đình (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + enterInviteCode() : void
          + displaySuccess() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + joinGroup(inviteCode: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + joinGroup(inviteCode: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + joinGroup(inviteCode: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + validateToken(inviteCode: String) : Boolean
          + addMemberToGroup(userId: String, groupId: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
