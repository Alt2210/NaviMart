@startuml
title UC002 Đăng nhập hệ thống (EmailSĐT) (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "View (React Component)" {
    class View <<View>> {
        + Nhập Email/SĐT & Mật khẩu() : void
          + Success & Redirect to Home() : void
    }
}

package "API Client" {
    class ApiClient <<API Client>> {
        + submitLogin(credentials) : void
    }
}

package "Backend Controller" {
    class Controller <<Controller>> {
        + submitLogin(credentials) : void
    }
}

package "Backend Service" {
    class Service <<Service>> {
        + submitLogin(credentials) : void
    }
}

package "Database Entity" {
    class UserEntity <<Entity>> {
  - user_id: INT
  - email: VARCHAR
  - phone: VARCHAR
  - password_hash: VARCHAR
  - role: VARCHAR
        + verifyCredentials() : void
    }
    class TokenManagerEntity <<Entity>> {
        + generateToken() : void
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> UserEntity : "CRUD"
Service ..> TokenManagerEntity : "CRUD"

@enduml
