@startuml
title UC012 Cập nhật phân quyền cho thành viên (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + selectRole() : void
          + displayUpdate() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + updateRole(groupId: String, memberId: String, newRole: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + updateRole(groupId: String, memberId: String, newRole: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + updateRole(groupId: String, memberId: String, newRole: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + updateMemberRole(groupId: String, memberId: String, newRole: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
