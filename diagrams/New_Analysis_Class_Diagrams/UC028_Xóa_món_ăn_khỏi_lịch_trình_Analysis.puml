@startuml
title UC028 Xóa món ăn khỏi lịch trình (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + selectMealToRemove() : void
          + displayResult() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + removeMeal(sessionId: String, mealId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + removeMeal(sessionId: String, mealId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + removeMeal(sessionId: String, mealId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + deleteMeal(sessionId: String, mealId: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
