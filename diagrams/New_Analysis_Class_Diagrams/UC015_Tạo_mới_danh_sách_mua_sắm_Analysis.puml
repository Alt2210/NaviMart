@startuml
title UC015 Tạo mới danh sách mua sắm (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + inputListName() : void
          + displayResult() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + createList(listName: String, groupId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + createList(listName: String, groupId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + createList(listName: String, groupId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + saveNewList(listName: String, groupId: String) : String
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
