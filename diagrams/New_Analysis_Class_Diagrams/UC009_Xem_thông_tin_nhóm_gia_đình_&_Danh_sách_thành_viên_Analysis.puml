@startuml
title UC009 Xem thông tin nhóm gia đình & Danh sách thành viên (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + requestGroupDetails() : void
          + displayGroupData() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + getGroupDetails(groupId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + getGroupDetails(groupId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + getGroupDetails(groupId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + queryGroupInfoAndMembers(groupId: String) : Data
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
