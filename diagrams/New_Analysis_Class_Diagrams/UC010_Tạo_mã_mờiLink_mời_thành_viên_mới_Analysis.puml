@startuml
title UC010 Tạo mã mờiLink mời thành viên mới (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + requestInviteToken() : void
          + displayInviteToken() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + generateInvite(groupId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + generateInvite(groupId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + generateInvite(groupId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + saveInviteToken(groupId: String, token: String, expiry: Date) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
