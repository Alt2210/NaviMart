@startuml
title UC005 Xem và Cập nhật thông tin cá nhân (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "View (React Component)" {
    class View <<View>> {
        + Sửa Name/Avatar & Lưu() : void
          + Cập nhật thành công() : void
    }
}

package "API Client" {
    class ApiClient <<API Client>> {
        + updateProfile(data) : void
    }
}

package "Backend Controller" {
    class Controller <<Controller>> {
        + updateProfile(data) : void
    }
}

package "Backend Service" {
    class Service <<Service>> {
        + updateProfile(data) : void
    }
}

package "Database Entity" {
    class ProfileEntity <<Entity>> {
        + save(data) : void
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> ProfileEntity : "CRUD"

@enduml
