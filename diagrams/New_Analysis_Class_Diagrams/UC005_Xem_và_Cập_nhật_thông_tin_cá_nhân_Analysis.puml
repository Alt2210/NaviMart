@startuml
title UC005 Xem và Cập nhật thông tin cá nhân (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + Sửa Name/Avatar & Lưu() : void
          + Cập nhật thành công() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + updateProfile(data) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + updateProfile(data) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + updateProfile(data) : void
    }
}

package "Entity" {
    class ProfileEntity <<Entity>> {
        + save(data) : void
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> ProfileEntity : "CRUD"

@enduml
