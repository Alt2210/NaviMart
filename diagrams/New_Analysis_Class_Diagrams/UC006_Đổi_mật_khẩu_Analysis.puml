@startuml
title UC006 Đổi mật khẩu (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "View (React Component)" {
    class View <<View>> {
        + Nhập Pass cũ & Pass mới() : void
          + Success Msg() : void
    }
}

package "API Client" {
    class ApiClient <<API Client>> {
        + changePassword(oldP, newP) : void
          + verifyOldPassword() : void
    }
}

package "Backend Controller" {
    class Controller <<Controller>> {
        + changePassword(oldP, newP) : void
          + verifyOldPassword() : void
    }
}

package "Backend Service" {
    class Service <<Service>> {
        + changePassword(oldP, newP) : void
          + verifyOldPassword() : void
    }
}

package "Database Entity" {
    class UserEntity <<Entity>> {
  - user_id: INT
  - email: VARCHAR
  - phone: VARCHAR
  - password_hash: VARCHAR
  - role: VARCHAR
        + fetchCurrentHash() : void
          + updateHash() : void
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> UserEntity : "CRUD"

@enduml
