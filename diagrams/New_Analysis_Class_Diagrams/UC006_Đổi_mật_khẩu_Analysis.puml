@startuml
title UC006 Đổi mật khẩu (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + Nhập Pass cũ & Pass mới() : void
          + Success Msg() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + changePassword(oldP, newP) : void
          + verifyOldPassword() : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + changePassword(oldP, newP) : void
          + verifyOldPassword() : void
    }
}

package "Control" {
    class Service <<Control>> {
        + changePassword(oldP, newP) : void
          + verifyOldPassword() : void
    }
}

package "Entity" {
    class UserEntity <<Entity>> {
  - user_id: INT
  - email: VARCHAR
  - phone: VARCHAR
  - password_hash: VARCHAR
  - role: VARCHAR
        + fetchCurrentHash() : void
          + updateHash() : void
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> UserEntity : "CRUD"

@enduml
