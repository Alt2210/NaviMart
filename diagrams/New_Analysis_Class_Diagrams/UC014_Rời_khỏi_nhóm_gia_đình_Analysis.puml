@startuml
title UC014 Rời khỏi nhóm gia đình (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + requestLeaveGroup() : void
          + displaySuccess() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + leaveGroup(groupId: String, userId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + leaveGroup(groupId: String, userId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + leaveGroup(groupId: String, userId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + removeMember(groupId: String, userId: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
