@startuml
title UC008 Tạo nhóm gia đình (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + enterGroupName() : void
          + displayResult() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + createGroup(groupName: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + createGroup(groupName: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + createGroup(groupName: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + saveNewGroup(groupName: String, ownerId: String) : String
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
