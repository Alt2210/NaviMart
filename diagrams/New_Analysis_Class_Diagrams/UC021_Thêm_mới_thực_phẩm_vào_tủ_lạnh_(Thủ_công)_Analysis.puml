@startuml
title UC021 Thêm mới thực phẩm vào tủ lạnh (Thủ công) (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + inputFoodDetails() : void
          + displaySuccess() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + addFood(foodDetails: Data) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + addFood(foodDetails: Data) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + addFood(foodDetails: Data) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + saveFood(foodDetails: Data) : String
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
