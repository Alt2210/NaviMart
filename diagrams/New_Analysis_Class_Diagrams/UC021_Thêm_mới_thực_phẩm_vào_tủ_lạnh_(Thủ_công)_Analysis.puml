@startuml
title UC021 Thêm mới thực phẩm vào tủ lạnh (Thủ công) (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "View (React Component)" {
    class View <<View>> {
        + inputFoodDetails() : void
          + displaySuccess() : void
    }
}

package "API Client" {
    class ApiClient <<API Client>> {
        + addFood(foodDetails: Data) : void
    }
}

package "Backend Controller" {
    class Controller <<Controller>> {
        + addFood(foodDetails: Data) : void
    }
}

package "Backend Service" {
    class Service <<Service>> {
        + addFood(foodDetails: Data) : void
    }
}

package "Database Entity" {
    class Entity <<Entity>> {
        + saveFood(foodDetails: Data) : String
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
