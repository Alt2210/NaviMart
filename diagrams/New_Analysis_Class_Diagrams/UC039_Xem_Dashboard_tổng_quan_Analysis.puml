@startuml
title UC039 Xem Dashboard tổng quan (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + requestDashboardData() : void
          + displayDashboard() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + getOverviewStats() : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + getOverviewStats() : void
    }
}

package "Control" {
    class Service <<Control>> {
        + getOverviewStats() : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + querySystemMetrics() : Data
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
