@startuml
title UC020 Xem và Tìm kiếm thực phẩm trong kho (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + enterSearchKeyword() : void
          + displayFoodList() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + searchFood(keyword: String, filters: Data) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + searchFood(keyword: String, filters: Data) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + searchFood(keyword: String, filters: Data) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + queryFoodList(keyword: String, filters: Data) : List
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
