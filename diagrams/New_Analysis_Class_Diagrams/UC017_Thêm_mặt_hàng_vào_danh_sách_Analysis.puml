@startuml
title UC017 Thêm mặt hàng vào danh sách (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + inputItemDetails() : void
          + displayUpdate() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + addItem(listId: String, itemName: String, quantity: Number) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + addItem(listId: String, itemName: String, quantity: Number) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + addItem(listId: String, itemName: String, quantity: Number) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + saveItem(listId: String, itemName: String, quantity: Number) : String
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
