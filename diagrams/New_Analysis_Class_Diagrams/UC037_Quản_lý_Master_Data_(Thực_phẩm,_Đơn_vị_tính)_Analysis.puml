@startuml
title UC037 Quản lý Master Data (Thực phẩm, Đơn vị tính) (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + manageData() : void
          + displayUpdate() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + executeCRUD(action: String, data: Data) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + executeCRUD(action: String, data: Data) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + executeCRUD(action: String, data: Data) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + updateDatabase(action: String, data: Data) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
