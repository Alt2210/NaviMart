@startuml
title UC001 Đăng ký tài khoản (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "View (React Component)" {
    class RegisterView <<View>> {
        + Chọn Đăng ký() : void
          + Điền & Gửi form() : void
          + Success (Chuyển Đăng nhập) : void
    }
    class OTPView <<View>> {
        + Require OTP() : void
          + Nhập OTP() : void
    }
}

package "API Client" {
    class AuthApiClient <<API Client>> {
        + submit(name, email_phone, password) : void
          + verifyOTP() : void
    }
    class EmailApiClient <<API Client>> {
        + sendOTP() : void
    }
}

package "Backend Controller" {
    class AuthController <<Controller>> {
        + submit(name, email_phone, password) : void
          + verifyOTP() : void
    }
    class EmailController <<Controller>> {
        + sendOTP() : void
    }
}

package "Backend Service" {
    class AuthService <<Service>> {
        + submit(name, email_phone, password) : void
          + verifyOTP() : void
    }
    class EmailService <<Service>> {
        + sendOTP() : void
    }
}

package "Database Entity" {
    class UserEntity <<Entity>> {
  - user_id: INT
  - email: VARCHAR
  - phone: VARCHAR
  - password_hash: VARCHAR
  - role: VARCHAR
        + checkExists() : void
          + savePending() : void
          + activateAccount() : void
    }
}

' --- Relationships ---
RegisterView --> AuthApiClient : "calls"
RegisterView --> EmailApiClient : "calls"
OTPView --> AuthApiClient : "calls"
OTPView --> EmailApiClient : "calls"
AuthApiClient ..> AuthController : "HTTP REST"
EmailApiClient ..> EmailController : "HTTP REST"
AuthController --> AuthService : "injects"
EmailController --> EmailService : "injects"
AuthService ..> UserEntity : "CRUD"
EmailService ..> UserEntity : "CRUD"

@enduml
