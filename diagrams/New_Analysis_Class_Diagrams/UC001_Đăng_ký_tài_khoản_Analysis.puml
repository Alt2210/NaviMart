@startuml
title UC001 Đăng ký tài khoản (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class RegisterView <<Boundary>> {
        + Chọn Đăng ký() : void
          + Điền & Gửi form() : void
          + Success (Chuyển Đăng nhập) : void
    }
    class OTPView <<Boundary>> {
        + Require OTP() : void
          + Nhập OTP() : void
    }
}

package "Boundary" {
    class AuthApiClient <<Boundary>> {
        + submit(name, email_phone, password) : void
          + verifyOTP() : void
    }
    class EmailApiClient <<Boundary>> {
        + sendOTP() : void
    }
}

package "Control" {
    class AuthController <<Control>> {
        + submit(name, email_phone, password) : void
          + verifyOTP() : void
    }
    class EmailController <<Control>> {
        + sendOTP() : void
    }
}

package "Control" {
    class AuthService <<Control>> {
        + submit(name, email_phone, password) : void
          + verifyOTP() : void
    }
    class EmailService <<Control>> {
        + sendOTP() : void
    }
}

package "Entity" {
    class UserEntity <<Entity>> {
  - user_id: INT
  - email: VARCHAR
  - phone: VARCHAR
  - password_hash: VARCHAR
  - role: VARCHAR
        + checkExists() : void
          + savePending() : void
          + activateAccount() : void
    }
}

' --- Relationships ---
RegisterView --> AuthApiClient : "calls"
RegisterView --> EmailApiClient : "calls"
OTPView --> AuthApiClient : "calls"
OTPView --> EmailApiClient : "calls"
AuthApiClient ..> AuthController : "HTTP REST"
EmailApiClient ..> EmailController : "HTTP REST"
AuthController --> AuthService : "injects"
EmailController --> EmailService : "injects"
AuthService ..> UserEntity : "CRUD"
EmailService ..> UserEntity : "CRUD"

@enduml
