@startuml
title UC035 Đăng nhập và Xem danh sách User (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + login() : void
          + viewUsers() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + loginAdmin(credentials: Data) : void
          + getUsersList(filters: Data) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + loginAdmin(credentials: Data) : void
          + getUsersList(filters: Data) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + loginAdmin(credentials: Data) : void
          + getUsersList(filters: Data) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + queryAllUsers(filters: Data) : List
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
