@startuml
title UC022 Cập nhật thông tin thực phẩm (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + selectFoodToUpdate() : void
          + displayUpdate() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + updateFood(foodId: String, updatedData: Data) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + updateFood(foodId: String, updatedData: Data) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + updateFood(foodId: String, updatedData: Data) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + updateFoodData(foodId: String, updatedData: Data) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
