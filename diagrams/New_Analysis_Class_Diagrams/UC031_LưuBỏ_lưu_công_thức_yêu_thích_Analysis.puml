@startuml
title UC031 LưuBỏ lưu công thức yêu thích (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + clickBookmark() : void
          + displayUpdate() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + toggleBookmark(recipeId: String, userId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + toggleBookmark(recipeId: String, userId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + toggleBookmark(recipeId: String, userId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + updateBookmarkStatus(recipeId: String, userId: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
