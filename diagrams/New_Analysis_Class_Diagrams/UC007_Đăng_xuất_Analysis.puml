@startuml
title UC007 Đăng xuất (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + Bấm Đăng xuất() : void
          + Redirect to Login() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + logout() : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + logout() : void
    }
}

package "Control" {
    class Service <<Control>> {
        + logout() : void
    }
}

package "Entity" {
    class SessionEntity <<Entity>> {
        + invalidateToken() : void
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> SessionEntity : "CRUD"

@enduml
