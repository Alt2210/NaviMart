@startuml
title UC034 Xem thống kê tiêu dùng và lãng phí (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + selectDateRange() : void
          + renderChart() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + getStatistics(dateRange: Data) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + getStatistics(dateRange: Data) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + getStatistics(dateRange: Data) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + queryUsageAndWasteData(dateRange: Data) : Data
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
