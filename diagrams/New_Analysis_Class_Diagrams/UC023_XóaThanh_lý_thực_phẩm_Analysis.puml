@startuml
title UC023 XóaThanh lý thực phẩm (Detailed Analysis Class)

skinparam class {
    BackgroundColor White
    ArrowColor #2C3E50
    BorderColor #2C3E50
}

package "Boundary" {
    class View <<Boundary>> {
        + selectFoodToRemove() : void
          + displayResult() : void
    }
}

package "Boundary" {
    class ApiClient <<Boundary>> {
        + removeFood(foodId: String) : void
    }
}

package "Control" {
    class Controller <<Control>> {
        + removeFood(foodId: String) : void
    }
}

package "Control" {
    class Service <<Control>> {
        + removeFood(foodId: String) : void
    }
}

package "Entity" {
    class Entity <<Entity>> {
        + deleteFoodData(foodId: String) : Boolean
    }
}

' --- Relationships ---
View --> ApiClient : "calls"
ApiClient ..> Controller : "HTTP REST"
Controller --> Service : "injects"
Service ..> Entity : "CRUD"

@enduml
