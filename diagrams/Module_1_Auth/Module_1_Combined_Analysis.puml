AuthController_Alias -- OAuthProviderGoogleFB_Alias
AuthController_Alias -- OAuthUI_Alias
AuthController_Alias -- ForgotPassUI_Alias
AuthController_Alias -- ResetPassUI_Alias
ProfileController_Alias -- ProfileUI_Alias
