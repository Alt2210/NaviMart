AuthController_Alias -- UserAccount_Alias
AuthController_Alias -- EmailService_Alias
AuthController_Alias -- OTPVerificationUI_Alias
AuthController_Alias -- LoginUI_Alias
AuthController_Alias -- TokenService_Alias
