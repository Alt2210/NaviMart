@startuml
title Sequence Diagram - UC027 ManageMeal

actor "User" as Actor
boundary "ManageMealSessionUI" as UI
control "MealSessionController" as Controller
entity "MealPlanDB" as Entity

Actor -> UI : 1. Chọn món ăn và gán vào phiên ăn
activate UI
UI -> Controller : 2. addOrUpdateMeal(sessionId, recipeId)
activate Controller
Controller -> Entity : 3. saveMealToSession(sessionId, recipeId)
activate Entity
Entity --> Controller : 4. success
deactivate Entity
Controller --> UI : 5. Trả về trạng thái thành công
deactivate Controller
UI --> Actor : 6. Hiển thị món ăn trong phiên ăn
deactivate UI
@enduml
