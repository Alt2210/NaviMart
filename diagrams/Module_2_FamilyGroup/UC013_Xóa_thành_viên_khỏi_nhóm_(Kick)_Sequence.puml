@startuml
title Sequence Diagram - UC013 RemoveMember

actor "User (Admin)" as Actor
boundary "RemoveMemberUI" as UI
control "MemberController" as Controller
entity "FamilyDB" as Entity

Actor -> UI : 1. Chọn thành viên & Nhấn "Xóa khỏi nhóm"
activate UI
UI -> Controller : 2. removeMember(groupId, memberId)
activate Controller
Controller -> Entity : 3. deleteMember(groupId, memberId)
activate Entity
Entity --> Controller : 4. success
deactivate Entity
Controller --> UI : 5. Thông báo xóa thành công
deactivate Controller
UI --> Actor : 6. Cập nhật lại danh sách thành viên
deactivate UI
@enduml
