@startuml
title Sequence Diagram - UC010 GenerateInviteCode

actor "User (Admin)" as Actor
boundary "InviteMemberUI" as UI
control "InviteController" as Controller
entity "FamilyDB" as Entity

Actor -> UI : 1. Chọn "Tạo mã mời"
activate UI
UI -> Controller : 2. generateInvite(groupId)
activate Controller
Controller -> Entity : 3. saveInviteToken(groupId, token, expiry)
activate Entity
Entity --> Controller : 4. success
deactivate Entity
Controller --> UI : 5. return inviteCode / Link
deactivate Controller
UI --> Actor : 6. Hiển thị mã mời / Link mời
deactivate UI
@enduml
