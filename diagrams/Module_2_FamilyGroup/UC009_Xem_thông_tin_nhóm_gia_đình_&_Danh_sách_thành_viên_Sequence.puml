@startuml
title Sequence Diagram - UC009 ViewFamilyMembers

actor "User" as Actor
boundary "ViewGroupUI" as UI
control "ViewGroupController" as Controller
entity "FamilyDB" as Entity

Actor -> UI : 1. Chọn xem chi tiết nhóm gia đình
activate UI
UI -> Controller : 2. getGroupDetails(groupId)
activate Controller
Controller -> Entity : 3. queryGroupInfoAndMembers(groupId)
activate Entity
Entity --> Controller : 4. return groupData, memberList
deactivate Entity
Controller --> UI : 5. Trả về dữ liệu nhóm
deactivate Controller
UI --> Actor : 6. Hiển thị danh sách thành viên và thông tin nhóm
deactivate UI
@enduml
