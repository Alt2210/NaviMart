@startuml
title Sequence Diagram - UC008 CreateFamilyGroup

actor "User" as Actor
boundary "CreateGroupUI" as UI
control "CreateGroupController" as Controller
entity "FamilyDB" as Entity

Actor -> UI : 1. Nhập tên nhóm & Chọn "Tạo nhóm"
activate UI
UI -> Controller : 2. createGroup(groupName)
activate Controller
Controller -> Entity : 3. saveNewGroup(groupName, ownerId)
activate Entity
Entity --> Controller : 4. return groupId
deactivate Entity
Controller --> UI : 5. Trả về thông báo thành công
deactivate Controller
UI --> Actor : 6. Hiển thị thông báo & Chuyển đến trang chi tiết nhóm
deactivate UI
@enduml
