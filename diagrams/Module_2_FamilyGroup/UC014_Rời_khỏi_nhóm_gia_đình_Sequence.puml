@startuml
title Sequence Diagram - UC014 LeaveFamilyGroup

actor "User" as Actor
boundary "LeaveGroupUI" as UI
control "LeaveGroupController" as Controller
entity "FamilyDB" as Entity

Actor -> UI : 1. Chọn "Rời nhóm"
activate UI
UI -> Controller : 2. leaveGroup(groupId, userId)
activate Controller
Controller -> Entity : 3. removeMember(groupId, userId)
activate Entity
Entity --> Controller : 4. success
deactivate Entity
Controller --> UI : 5. Thông báo rời nhóm thành công
deactivate Controller
UI --> Actor : 6. Chuyển về màn hình danh sách nhóm
deactivate UI
@enduml
