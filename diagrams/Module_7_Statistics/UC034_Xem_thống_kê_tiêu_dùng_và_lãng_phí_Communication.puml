@startuml
title Communication Diagram - UC034 ViewStatistics

allow_mixing
actor "User" as Actor
boundary "ViewStatisticsUI" as UI
control "ViewStatisticsController" as Controller
entity "ViewStatisticsDB" as Entity

Actor -right-> UI : 1: Interact
UI -right-> Controller : 2: process()
Controller -down-> Entity : 3: dbAction()
Controller -up-> UI : 4: returnData
@enduml
