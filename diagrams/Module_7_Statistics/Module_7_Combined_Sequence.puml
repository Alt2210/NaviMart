@startuml
title Combined Sequence Diagram - Module 7 (Statistics)

actor "User" as Actor
boundary "StatisticsUI" as UI
control "StatController" as Controller
entity "StatDB" as Entity

group UC034 Xem thống kê tiêu dùng và lãng phí
  Actor -> UI : Chọn tab Thống kê & khoảng thời gian
  activate UI
  UI -> Controller : getStatistics(dateRange)
  activate Controller
  Controller -> Entity : queryUsageAndWasteData(dateRange)
  activate Entity
  Entity --> Controller : return aggregatedData
  deactivate Entity
  Controller --> UI : return chartData
  deactivate Controller
  UI --> Actor : Vẽ và hiển thị biểu đồ
  deactivate UI
end

@enduml
