@startuml
title Sequence Diagram - UC034 ViewStatistics

actor "User" as Actor
boundary "StatisticsDashboardUI" as UI
control "StatisticsController" as Controller
entity "StatDB" as Entity

Actor -> UI : 1. Chọn tab Thống kê & Chọn khoảng thời gian
activate UI
UI -> Controller : 2. getStatistics(dateRange)
activate Controller
Controller -> Entity : 3. queryUsageAndWasteData(dateRange)
activate Entity
Entity --> Controller : 4. return aggregatedData
deactivate Entity
Controller --> UI : 5. return chartData
deactivate Controller
UI --> Actor : 6. Vẽ và hiển thị biểu đồ tiêu dùng & lãng phí
deactivate UI
@enduml
