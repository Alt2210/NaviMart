@startuml
title Communication Diagram - UC019 FinishShopping

allow_mixing
actor "User" as Actor
boundary "FinishShoppingUI" as UI
control "FinishShoppingController" as Controller
entity "FinishShoppingDB" as Entity

Actor -right-> UI : 1: Interact
UI -right-> Controller : 2: process()
Controller -down-> Entity : 3: dbAction()
Controller -up-> UI : 4: returnData
@enduml
