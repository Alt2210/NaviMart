@startuml
title Analysis Class Diagram - UC019 FinishShopping

class "MarkItemBoughtUI" as UI <<boundary>> {
  + checkItemAsBought() : void
  + displayUpdate() : void
}
class "ShoppingItemController" as Controller <<control>> {
  + markItemAsBought(itemId: String) : void
}
class "ShoppingDB" as ShoppingDB <<entity>> {
  + updateItemStatus(itemId: String, status: String) : Boolean
}
class "PantryController" as PantryController <<control>> {
  + transferItemToPantry(itemDetails: Data) : void
}
class "PantryDB" as PantryDB <<entity>> {
  + addFood(itemDetails: Data) : Boolean
}

Controller -- UI
Controller -- ShoppingDB
Controller -- PantryController
PantryController -- PantryDB
@enduml
