@startuml
title Sequence Diagram - UC025 ExpiryNotification

actor "System (CronJob)" as Cron
control "NotificationController" as Controller
entity "PantryDB" as DB
control "NotificationService" as NotifService
actor "User" as Actor

Cron -> Controller : 1. triggerCheckExpiryDaily()
activate Controller
Controller -> DB : 2. queryExpiringFoods(daysLimit)
activate DB
DB --> Controller : 3. return expiringFoodsList
deactivate DB
Controller -> NotifService : 4. sendExpiryWarning(userId, foods)
activate NotifService
NotifService --> Actor : 5. Gửi Push Notification / Email nhắc nhở
NotifService --> Controller : 6. deliveryStatus
deactivate NotifService
Controller --> Cron : 7. jobCompleted
deactivate Controller
@enduml
