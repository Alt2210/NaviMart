@startuml
title Analysis Class Diagram - UC024 AutoDeductFood

class "MealPlanUI" as UI <<boundary>> {
  + confirmMealCooked() : void
  + displayUpdate() : void
}
class "MealController" as MealController <<control>> {
  + confirmMealCooked(mealId: String) : void
}
class "PantryController" as PantryController <<control>> {
  + deductIngredients(ingredients: List) : void
}
class "PantryDB" as PantryDB <<entity>> {
  + decreaseFoodQuantity(ingredients: List) : Boolean
}

MealController -- UI
MealController -- PantryController
PantryController -- PantryDB
@enduml
