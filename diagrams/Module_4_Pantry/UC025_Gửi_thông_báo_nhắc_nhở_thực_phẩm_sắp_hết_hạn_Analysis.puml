@startuml
title Analysis Class Diagram - UC025 ExpiryNotification

class "CronJob" as Cron <<actor>>
class "NotificationController" as Controller <<control>> {
  + triggerCheckExpiryDaily() : void
}
class "PantryDB" as DB <<entity>> {
  + queryExpiringFoods(daysLimit: Number) : List
}
class "NotificationService" as NotifService <<control>> {
  + sendExpiryWarning(userId: String, foods: List) : void
}
class "User" as Actor <<actor>>

Cron -- Controller
Controller -- DB
Controller -- NotifService
NotifService -- Actor
@enduml
