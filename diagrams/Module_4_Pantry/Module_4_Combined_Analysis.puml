}

class "RemoveFoodUI" as RemoveFoodUI_Alias <<boundary>> {
  + selectFoodToRemove() : void
  + displayResult() : void
}

class "MealPlanUI" as MealPlanUI_Alias <<boundary>> {
  + confirmMealCooked() : void
  + displayUpdate() : void
}

class "MealController" as MealController_Alias <<control>> {
