@startuml
title Communication Diagram - UC020 ViewPantry

allow_mixing
actor "User" as Actor
boundary "ViewPantryUI" as UI
control "ViewPantryController" as Controller
entity "ViewPantryDB" as Entity

Actor -right-> UI : 1: Interact
UI -right-> Controller : 2: process()
Controller -down-> Entity : 3: dbAction()
Controller -up-> UI : 4: returnData
@enduml
